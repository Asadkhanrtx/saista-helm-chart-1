# ── Database (AWS RDS MySQL) ─────────────────────────────────
DB_HOST=YOUR_RDS_ENDPOINT.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=YOUR_RDS_PASSWORD
DB_NAME=saista_bakers
DB_PORT=3306

# ── JWT Secret (must be identical across all 3 services) ─────
SECRET_KEY=saista-bakers-secret-key-2024-production

# ── Cross-service URLs (localhost = all services on same EC2) ─
USER_SERVICE_URL=http://localhost:5001